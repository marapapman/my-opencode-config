{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [],
    "agent": {
        "explore": {
            "disable": true
        },
        "general": {
            "disable": true
        }
    },
    "lsp": true,
    "mcp": {
        "exa": {
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
            "enabled": true,
            "headers": {
                "x-api-key": "YOUR_EXA_API_KEY"
            }
        },
        "zenmux-mcp": {
            "type": "local",
            "command": ["YOUR_REPO_PATH/mcp/zenmux-mcp/.venv/bin/python", "YOUR_REPO_PATH/mcp/zenmux-mcp/server.py"],
            "enabled": true,
            "environment": {
                "ZENMUX_API_KEY": "YOUR_ZENMUX_API_KEY",
                "ZENMUX_IMAGE_DIR": "/tmp/opencode/zenmux-images"
            },
            "timeout": 120000
        }
    },
    "permission": {
        "websearch": "allow",
        "webfetch": "allow"
    }
}
