{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [],
    "agent": {
        "explore": {
            "disable": true
        },
        "general": {
            "disable": true
        }
    },
    "lsp": true,
    "mcp": {
        "exa": {
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
            "enabled": true,
            "headers": {
                "x-api-key": "YOUR_EXA_API_KEY"
            }
        }
    },
    "permission": {
        "websearch": "allow",
        "webfetch": "allow"
    }
}
